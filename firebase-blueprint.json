{
  "entities": {
    "Structure": {
      "title": "Structure",
      "description": "A reusable construction structure definition",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the structure" },
        "materials": { 
          "type": "array", 
          "items": { "$ref": "Material" },
          "description": "List of materials composing the structure"
        },
        "createdAt": { "type": "number", "format": "timestamp" },
        "updatedAt": { "type": "number", "format": "timestamp" },
        "ownerUid": { "type": "string", "description": "UID of the user who created the structure" }
      },
      "required": ["name", "materials", "ownerUid"]
    },
    "Material": {
      "title": "Material",
      "description": "A single material component",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "cost": { "type": "number" }
      },
      "required": ["name", "unit", "quantity"]
    },
    "Project": {
      "title": "Project",
      "description": "A construction project or quote",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "client": { "type": "string" },
        "type": { "type": "string", "enum": ["proyecto", "cotización"] },
        "structures": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "structureId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] },
        "completionDate": { "type": "number", "format": "timestamp" },
        "createdAt": { "type": "number", "format": "timestamp" },
        "updatedAt": { "type": "number", "format": "timestamp" },
        "ownerUid": { "type": "string" }
      },
      "required": ["name", "client", "structures", "status", "ownerUid"]
    }
  },
  "firestore": {
    "/structures/{structureId}": {
      "schema": "Structure",
      "description": "Collection of reusable structures"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects and quotes"
    }
  }
}
